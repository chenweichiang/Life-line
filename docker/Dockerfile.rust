FROM rust:1.75-bookworm

# 安裝顯示、GPU 驅動與聲音所需的依賴庫 (X11, Wayland, ALSA)
RUN apt-get update && apt-get install -y \
    pkg-config \
    libx11-dev \
    libasound2-dev \
    libudev-dev \
    libwayland-dev \
    libxkbcommon-dev \
    vulkan-tools \
    mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 初始化 Cargo 但不編譯
CMD ["bash"]
